name: Sync Xiaomi source to target repo

on:
  workflow_dispatch:  # manual trigger

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout (dummy, but needed for git operations)
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Configure git
        run: |
          git config --global user.name "github-actions"
          git config --global user.email "actions@github.com"

      - name: Clone Xiaomi source
        run: |
          git clone https://github.com/MiCode/Xiaomi_Kernel_OpenSource.git
          cd Xiaomi_Kernel_OpenSource
          git checkout lime-q-oss

      - name: Push to target repo as main
        env:
          TOKEN: ${{ secrets.PERSONAL_ACCESS_TOKEN }}
        run: |
          cd Xiaomi_Kernel_OpenSource
          git remote add target https://rzmio:${TOKEN}@github.com/rzmio/kernel_xiaomi_citrus.git
          git push --force target lime-q-oss:main
